{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nihong-jastip",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": ".open-next/output/assets",
  "main": ".open-next/worker.js",

  // Environment variables (pastikan set via Cloudflare Dashboard > Settings > Variables)
  // Jangan hardcode API key di sini!
  // "vars": { "GROQ_API_KEY": "gsk_xxx" }
}
